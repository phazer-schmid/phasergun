# ─── Provider Mode ──────────────────────────────────────────────────────────
# Route all LLM calls through Azure AI Foundry instead of direct provider APIs.
PROVIDER_MODE=azure_foundry

# ─── Direct API Keys — NOT used in azure_foundry mode ───────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Azure Foundry Settings ──────────────────────────────────────────────────
# Endpoint for your Azure AI Foundry hub (no trailing slash).
AZURE_ENDPOINT=https://YOUR-HUB-NAME.openai.azure.com
# API key for the Foundry endpoint (not an OpenAI key — get this from Azure portal).
AZURE_API_KEY=YOUR-AZURE-API-KEY
# API version. Leave as-is unless Azure instructs you to upgrade.
AZURE_API_VERSION=2024-12-01-preview
# Optional prefix prepended to model IDs to form Azure deployment names.
# e.g. "phasergun-" + "gpt-4o-mini" → deployment name "phasergun-gpt-4o-mini"
# Leave blank if your Azure deployments use the bare model name.
AZURE_DEPLOYMENT_PREFIX=phasergun-

# ─── Model Role Assignments (override defaults) ──────────────────────────────
# These must match the deployment names you created in Azure AI Foundry
# (after stripping the AZURE_DEPLOYMENT_PREFIX, if set).
# MODEL_INGESTION=gpt-4o-mini
# MODEL_DRAFTER=gpt-4.1
# MODEL_AUDITOR=o3-mini
# MODEL_REVISER=gpt-4.1
# MODEL_EMBEDDINGS=text-embedding-3-large

# ─── Token Limits (optional per-role overrides) ──────────────────────────────
# TOKENS_DRAFTER=8192
# TOKENS_AUDITOR=4096

# ─── Pipeline Step Toggles ───────────────────────────────────────────────────
ENABLE_INGESTION_STEP=true
ENABLE_AUDIT_STEP=true
ENABLE_REVISION_STEP=true

# ─── Activate multi-model mode ───────────────────────────────────────────────
LLM_MODE=multi-model

# ─── Existing required settings (unchanged) ──────────────────────────────────
PRIMARY_CONTEXT_PATH=...
NODE_ENV=production
