# ─── Provider Mode ──────────────────────────────────────────────────────────
# "direct"        = call OpenAI/Anthropic APIs directly (Phase 1)
# "azure_foundry" = route through Azure AI Foundry (Phase 2)
PROVIDER_MODE=direct

# ─── Direct API Keys (used when PROVIDER_MODE=direct) ───────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Azure Foundry Settings (used when PROVIDER_MODE=azure_foundry) ─────────
# AZURE_ENDPOINT=https://YOUR-HUB-NAME.openai.azure.com
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-12-01-preview
# AZURE_DEPLOYMENT_PREFIX=phaser-

# ─── Model Role Assignments (override defaults) ──────────────────────────────
# Uncomment and edit any line to override the default model for that role.
# MODEL_INGESTION=gpt-4o-mini
# MODEL_DRAFTER=gpt-4.1
# MODEL_AUDITOR=o3-mini
# MODEL_REVISER=gpt-4.1
# MODEL_EMBEDDINGS=text-embedding-3-large

# ─── Token Limits (optional per-role overrides) ──────────────────────────────
# TOKENS_DRAFTER=8192
# TOKENS_AUDITOR=4096

# ─── Pipeline Step Toggles ───────────────────────────────────────────────────
# Set any to "false" to disable that step for this deployment.
ENABLE_INGESTION_STEP=true
ENABLE_AUDIT_STEP=true
ENABLE_REVISION_STEP=true

# ─── Activate multi-model mode ───────────────────────────────────────────────
LLM_MODE=multi-model

# ─── Existing required settings (unchanged) ──────────────────────────────────
PRIMARY_CONTEXT_PATH=...
NODE_ENV=production
